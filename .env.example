CHARON_APP_ENV=development
CHARON_API_HTTP_ADDR=:8080
CHARON_PUBLIC_BASE_URL=http://localhost:8080
CHARON_POSTGRES_URL=postgres://charon:charon@localhost:5432/charon?sslmode=disable
CHARON_REDIS_URL=redis://localhost:6379/0
CHARON_RABBITMQ_URL=amqp://guest:guest@localhost:5672/
CHARON_ADMIN_WEB_URL=http://localhost:3000
CHARON_ACCESS_TOKEN_SECRET=replace-with-a-long-random-secret
CHARON_REFRESH_TOKEN_PEPPER=replace-with-a-different-long-random-secret
CHARON_JWT_ISSUER=charon
CHARON_ACCESS_TOKEN_TTL=15m
CHARON_REFRESH_TOKEN_TTL=720h
